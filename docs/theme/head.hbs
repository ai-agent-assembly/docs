<!-- Google Analytics 4 (gtag.js) + Consent Mode v2 — agent-assembly-docs hub.
     The Measurement ID is public (embedded client-side), not a secret.
     Analytics storage is denied by default and only enabled after explicit
     opt-in. AAASM-3552 / AAASM-3554. -->
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }
  // Consent Mode v2 — deny analytics/ads storage until the visitor opts in.
  gtag('consent', 'default', {
    'analytics_storage': 'denied',
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied'
  });
  // Re-apply a stored opt-in before the first hit fires.
  try {
    if (window.localStorage && localStorage.getItem('aa-analytics-consent') === 'granted') {
      gtag('consent', 'update', { 'analytics_storage': 'granted' });
    }
  } catch (e) {}
  gtag('js', new Date());
  gtag('config', 'G-EZTLJDFS6J', { 'anonymize_ip': true });
</script>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-EZTLJDFS6J"></script>

<!-- Opt-in cookie-consent banner (vanilla JS, no external request) — AAASM-3554. -->
<style>
  .aa-consent { position: fixed; left: 1rem; right: 1rem; bottom: 1rem; z-index: 2147483647;
    max-width: 42rem; margin: 0 auto; padding: 1rem 1.25rem; border-radius: 8px;
    background: #1f2430; color: #e7eaf0; box-shadow: 0 4px 24px rgba(0, 0, 0, .35);
    font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .aa-consent p { margin: 0 0 .75rem; }
  .aa-consent a { color: #8ab4f8; }
  .aa-consent__actions { display: flex; gap: .5rem; flex-wrap: wrap; }
  .aa-consent button { cursor: pointer; border: 0; border-radius: 6px; padding: .45rem .9rem;
    font-size: 14px; font-weight: 600; }
  .aa-consent__accept { background: #8ab4f8; color: #14161b; }
  .aa-consent__reject { background: transparent; color: #e7eaf0; border: 1px solid #4a5160; }
</style>
<script>
  (function () {
    var KEY = 'aa-analytics-consent';
    function stored() {
      try { return window.localStorage && localStorage.getItem(KEY); } catch (e) { return null; }
    }
    if (stored()) { return; } // visitor already chose — no banner
    function choose(value) {
      try { localStorage.setItem(KEY, value); } catch (e) {}
      if (value === 'granted' && typeof gtag === 'function') {
        gtag('consent', 'update', { 'analytics_storage': 'granted' });
      }
      var box = document.querySelector('.aa-consent');
      if (box && box.parentNode) { box.parentNode.removeChild(box); }
    }
    function build() {
      if (stored() || document.querySelector('.aa-consent')) { return; }
      var box = document.createElement('div');
      box.className = 'aa-consent';
      box.setAttribute('role', 'dialog');
      box.setAttribute('aria-live', 'polite');
      box.setAttribute('aria-label', 'Cookie consent');
      var text = document.createElement('p');
      text.textContent = 'We use Google Analytics to understand documentation usage. '
        + 'Analytics cookies are only set if you accept.';
      var actions = document.createElement('div');
      actions.className = 'aa-consent__actions';
      var accept = document.createElement('button');
      accept.type = 'button';
      accept.className = 'aa-consent__accept';
      accept.textContent = 'Accept';
      accept.addEventListener('click', function () { choose('granted'); });
      var reject = document.createElement('button');
      reject.type = 'button';
      reject.className = 'aa-consent__reject';
      reject.textContent = 'Reject';
      reject.addEventListener('click', function () { choose('denied'); });
      actions.appendChild(accept);
      actions.appendChild(reject);
      box.appendChild(text);
      box.appendChild(actions);
      document.body.appendChild(box);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', build);
    } else {
      build();
    }
  })();
</script>

<!-- "Was this page helpful?" feedback widget (vanilla JS) — AAASM-3555. -->
<style>
  .aa-feedback { margin: 3rem 0 1rem; padding-top: 1.25rem; border-top: 1px solid rgba(127, 127, 127, .25);
    font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .aa-feedback__q { font-weight: 600; margin: 0 0 .5rem; }
  .aa-feedback__actions { display: flex; gap: .5rem; align-items: center; }
  .aa-feedback__btn { cursor: pointer; border: 1px solid rgba(127, 127, 127, .4); background: transparent;
    color: inherit; border-radius: 6px; padding: .35rem .75rem; font-size: 14px; line-height: 1; }
  .aa-feedback__btn:hover { border-color: #8ab4f8; }
  .aa-feedback__msg { margin: .5rem 0 0; }
  .aa-feedback__msg a { color: #8ab4f8; }
</style>
<script>
  (function () {
    // Per-site repo for the "tell us what to improve" pre-filled issue link.
    var REPO = 'docs';
    function sendFeedback(value) {
      // Consent Mode (AAASM-3554) governs whether this hit is stored; fire either way.
      if (typeof gtag === 'function') {
        gtag('event', 'feedback', { 'value': value, 'page_path': location.pathname });
      }
    }
    function issueUrl() {
      var title = 'Docs feedback: ' + location.pathname;
      var body = 'Page: ' + location.href + '\n\nWhat could be improved?\n';
      return 'https://github.com/ai-agent-assembly/' + REPO + '/issues/new?labels=docs,feedback'
        + '&title=' + encodeURIComponent(title) + '&body=' + encodeURIComponent(body);
    }
    function build() {
      var main = document.querySelector('main');
      if (!main || document.querySelector('.aa-feedback')) { return; }
      var box = document.createElement('div');
      box.className = 'aa-feedback';
      var q = document.createElement('p');
      q.className = 'aa-feedback__q';
      q.textContent = 'Was this page helpful?';
      var actions = document.createElement('div');
      actions.className = 'aa-feedback__actions';
      var msg = document.createElement('p');
      msg.className = 'aa-feedback__msg';
      function done(text, withLink) {
        if (actions.parentNode) { actions.parentNode.removeChild(actions); }
        msg.textContent = text;
        if (withLink) {
          msg.appendChild(document.createTextNode(' '));
          var a = document.createElement('a');
          a.href = issueUrl();
          a.target = '_blank';
          a.rel = 'noopener';
          a.textContent = 'Tell us what we can improve →';
          msg.appendChild(a);
        }
      }
      var yes = document.createElement('button');
      yes.type = 'button';
      yes.className = 'aa-feedback__btn';
      yes.textContent = '👍 Yes';
      yes.addEventListener('click', function () { sendFeedback(1); done('Thanks for your feedback!', false); });
      var no = document.createElement('button');
      no.type = 'button';
      no.className = 'aa-feedback__btn';
      no.textContent = '👎 No';
      no.addEventListener('click', function () { sendFeedback(0); done('Thanks — sorry this page missed the mark.', true); });
      actions.appendChild(yes);
      actions.appendChild(no);
      box.appendChild(q);
      box.appendChild(actions);
      box.appendChild(msg);
      main.appendChild(box);
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', build);
    } else {
      build();
    }
  })();
</script>

<!-- Unified search across the hub + all module docs (AAASM-3664).
     Pagefind indexes the FINAL aggregated public/ at build time (see
     docs/scripts/aggregate.sh), so this one box searches the hub, core,
     python-sdk, node-sdk and go-sdk together. Assets live at {{ path_to_root }}pagefind/ (base-path-aware via mdBook
     path_to_root, so it works under a project subpath like
     github.io/docs/ AND at the root docs.agent-assembly.com).
     When the hub is
     built standalone (no aggregation), /pagefind/ is absent and the widget
     silently no-ops — the mdBook native search still works. -->
<link href="{{ path_to_root }}pagefind/pagefind-ui.css" rel="stylesheet" onerror="this.dataset.failed=1">
<script src="{{ path_to_root }}pagefind/pagefind-ui.js" onerror="window.__aaPagefindMissing=1"></script>
<style>
  .aa-search { margin: 0 0 1rem; }
  .aa-search__open { cursor: pointer; width: 100%; text-align: left; border: 1px solid rgba(127,127,127,.4);
    background: transparent; color: inherit; border-radius: 8px; padding: .5rem .85rem; font-size: 14px; }
  .aa-search__open:hover { border-color: #8ab4f8; }
  .aa-search__modal { position: fixed; inset: 0; z-index: 2147483646; display: none;
    background: rgba(0,0,0,.45); }
  .aa-search__modal.is-open { display: block; }
  .aa-search__panel { max-width: 44rem; margin: 6vh auto 0; background: var(--bg, #fff); color: inherit;
    border-radius: 10px; padding: 1rem; box-shadow: 0 10px 40px rgba(0,0,0,.4); }
  html[data-theme="navy"] .aa-search__panel,
  html[data-theme="coal"] .aa-search__panel,
  html[data-theme="ayu"] .aa-search__panel { background: #1f2430; }
  .aa-search__hint { font-size: 12px; opacity: .7; margin: .5rem 0 0; }
</style>
<script>
  (function () {
    function init() {
      if (window.__aaPagefindMissing || typeof PagefindUI === 'undefined') { return; }
      // Inject a search trigger at the top of the mdBook content area.
      var content = document.querySelector('#content main') || document.querySelector('main');
      if (!content || document.querySelector('.aa-search')) { return; }
      var wrap = document.createElement('div');
      wrap.className = 'aa-search';
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'aa-search__open';
      btn.textContent = '🔎  Search all docs (hub · core · python · node · go) …';
      var modal = document.createElement('div');
      modal.className = 'aa-search__modal';
      var panel = document.createElement('div');
      panel.className = 'aa-search__panel';
      var box = document.createElement('div');
      box.id = 'aa-pagefind-search';
      var hint = document.createElement('p');
      hint.className = 'aa-search__hint';
      hint.textContent = 'Searches the hub and every module. Press Esc to close.';
      panel.appendChild(box); panel.appendChild(hint); modal.appendChild(panel);
      wrap.appendChild(btn);
      content.insertBefore(wrap, content.firstChild);
      document.body.appendChild(modal);

      var built = false;
      function open() {
        if (!built) {
          // Derive an ABSOLUTE bundlePath from the loaded UI script URL: PagefindUI
          // import()s `${bundlePath}pagefind.js`, and a relative/bare path fails to
          // resolve as a module specifier. The resolved script .src is absolute and
          // correct under both the github.io project subpath and the root domain.
          var __pfs = document.querySelector('script[src$="pagefind/pagefind-ui.js"]');
          var __pfBase = __pfs ? __pfs.src.replace(/pagefind-ui\.js(\?.*)?$/, '') : new URL('{{ path_to_root }}pagefind/', location.href).href;
          new PagefindUI({ element: '#aa-pagefind-search', bundlePath: __pfBase, showSubResults: true, showImages: false });
          built = true;
        }
        modal.classList.add('is-open');
        var input = panel.querySelector('input');
        if (input) { input.focus(); }
      }
      function close() { modal.classList.remove('is-open'); }
      btn.addEventListener('click', open);
      modal.addEventListener('click', function (e) { if (e.target === modal) { close(); } });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') { close(); } });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else { init(); }
  })();
</script>

<!-- Hub-level module + version switcher (AAASM-3758).
     A persistent header on every hub page that lets you jump straight to any
     aggregated module at any version/channel WITHOUT first opening that module.
     It is driven entirely by the manifests the aggregation already produces —
     {{ path_to_root }}modules.json (module list + subpaths, copied verbatim by
     docs/scripts/aggregate.sh) and each {{ path_to_root }}<subpath>/versions.json
     (the same manifest each module's own per-version switcher reads). There are
     NO hard-coded module or version strings here. Selecting a module + version
     navigates to /<subpath>/<channel-or-tag>/. A module whose versions.json is
     absent (e.g. node-sdk / go-sdk, or a hub built standalone with no
     aggregation) degrades gracefully: it is still listed and its option links to
     the module root. If modules.json itself is absent the widget silently
     no-ops, exactly like the Pagefind search above. base-path-aware via mdBook's
     {{ path_to_root }} so it works under the github.io project subpath AND at the
     root docs.agent-assembly.com. -->
<style>
  .aa-modswitch { margin: 0 0 1rem; padding: .6rem .85rem; border: 1px solid rgba(127,127,127,.4);
    border-radius: 8px; display: flex; flex-wrap: wrap; gap: .5rem; align-items: center;
    font: 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
  .aa-modswitch__label { font-weight: 600; margin-right: .15rem; }
  .aa-modswitch select { cursor: pointer; border: 1px solid rgba(127,127,127,.4); background: transparent;
    color: inherit; border-radius: 6px; padding: .35rem .5rem; font-size: 14px; max-width: 18rem; }
  html[data-theme="navy"] .aa-modswitch select option,
  html[data-theme="coal"] .aa-modswitch select option,
  html[data-theme="ayu"] .aa-modswitch select option { background: #1f2430; color: #e7eaf0; }
  .aa-modswitch__go { cursor: pointer; border: 0; border-radius: 6px; padding: .4rem .85rem;
    font-size: 14px; font-weight: 600; background: #8ab4f8; color: #14161b; text-decoration: none; }
  .aa-modswitch__go:hover { filter: brightness(1.05); }
</style>
<script>
  (function () {
    // base-path-aware root (works under github.io/docs/ AND the root domain).
    var ROOT = '{{ path_to_root }}';

    function el(tag, attrs) {
      var n = document.createElement(tag);
      for (var k in attrs) { if (attrs.hasOwnProperty(k)) { n.setAttribute(k, attrs[k]); } }
      return n;
    }
    function option(value, label) {
      var o = document.createElement('option');
      o.value = value; o.textContent = label;
      return o;
    }
    function prettyModule(name) {
      // Display-only label; never affects navigation (which uses subpath).
      return name.replace(/-/g, ' ').replace(/\bsdk\b/gi, 'SDK')
                 .replace(/^\w/, function (c) { return c.toUpperCase(); });
    }
    // Normalise either manifest shape into a flat [{value, label}] option list.
    //   core (mdBook)  -> { channels:[{id,title}], archived:[{id,title}] }
    //   python (mike)  -> [ {version,title,aliases:[...]} ]
    // value is the subpath segment to navigate to (/<module>/<value>/).
    function optionsFromManifest(data) {
      var opts = [];
      if (Array.isArray(data)) {
        data.forEach(function (e) {
          if (!e || !e.version) { return; }
          var label = e.title || e.version;
          if (e.aliases && e.aliases.length) { label += ' — ' + e.aliases.join(' / '); }
          opts.push({ value: e.version, label: label });
        });
      } else if (data && typeof data === 'object') {
        (data.channels || []).forEach(function (c) {
          if (c && c.id) { opts.push({ value: c.id, label: c.title || c.id }); }
        });
        (data.archived || []).forEach(function (a) {
          if (a && a.id) { opts.push({ value: a.id, label: a.title || a.id }); }
        });
      }
      return opts;
    }

    function build(modules) {
      var content = document.querySelector('#content main') || document.querySelector('main');
      if (!content || !modules.length || document.querySelector('.aa-modswitch')) { return; }

      var bar = el('div', { 'class': 'aa-modswitch', 'role': 'group', 'aria-label': 'Browse module documentation' });
      var label = el('span', { 'class': 'aa-modswitch__label' });
      label.textContent = 'Browse module docs:';
      var modSel = el('select', { 'class': 'aa-modswitch__mod', 'aria-label': 'Module' });
      var verSel = el('select', { 'class': 'aa-modswitch__ver', 'aria-label': 'Version or channel' });
      var go = el('a', { 'class': 'aa-modswitch__go', 'href': '#' });
      go.textContent = 'Go →';

      modules.forEach(function (m) {
        if (m && m.name && m.subpath) { modSel.appendChild(option(m.subpath, prettyModule(m.name))); }
      });

      function targetUrl() {
        var sub = modSel.value;
        var ver = verSel.value;
        return ROOT + sub + '/' + (ver ? ver + '/' : '');
      }
      function loadVersions() {
        var sub = modSel.value;
        verSel.innerHTML = '';
        verSel.disabled = true;
        verSel.appendChild(option('', 'Loading…'));
        fetch(ROOT + sub + '/versions.json', { cache: 'no-cache' })
          .then(function (r) { if (!r.ok) { throw new Error('no manifest'); } return r.json(); })
          .then(function (data) {
            var opts = optionsFromManifest(data);
            verSel.innerHTML = '';
            if (!opts.length) { throw new Error('empty manifest'); }
            opts.forEach(function (o) { verSel.appendChild(option(o.value, o.label)); });
            verSel.disabled = false;
          })
          .catch(function () {
            // No (or unreadable) versions.json — still navigable; fall back to the module root.
            verSel.innerHTML = '';
            verSel.appendChild(option('', 'latest'));
            verSel.disabled = false;
          });
      }

      modSel.addEventListener('change', loadVersions);
      go.addEventListener('click', function (e) { e.preventDefault(); location.href = targetUrl(); });
      verSel.addEventListener('keydown', function (e) { if (e.key === 'Enter') { location.href = targetUrl(); } });

      bar.appendChild(label);
      bar.appendChild(modSel);
      bar.appendChild(verSel);
      bar.appendChild(go);
      content.insertBefore(bar, content.firstChild);
      loadVersions();
    }

    function init() {
      if (document.querySelector('.aa-modswitch')) { return; }
      fetch(ROOT + 'modules.json', { cache: 'no-cache' })
        .then(function (r) { if (!r.ok) { throw new Error('no modules.json'); } return r.json(); })
        .then(function (data) { build((data && data.modules) || []); })
        .catch(function () { /* standalone hub build (no aggregation) — silently no-op */ });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else { init(); }
  })();
</script>
